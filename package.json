{
  "name": "multiple_lang_sandbox",
  "version": "1.0.0",
  "description": "multiple tech sandbox",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.1.0",
  "engines": {
    "bun": ">=1.1.0"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "bunx eslint \"packages/**/{src,test}/**/*.{js,jsx,ts,tsx,json}\"",
    "lint:fix": "bunx eslint --fix \"packages/**/{src,test}/**/*.{js,jsx,ts,tsx,json}\"",
    "format": "bunx prettier --no-error-on-unmatched-pattern --write \"packages/**/{src,test}/**/*.{js,jsx,ts,tsx,css,md,json}\" --config .prettierrc",
    "format:check": "bunx prettier --no-error-on-unmatched-pattern --check \"packages/**/{src,test}/**/*.{js,jsx,ts,tsx,css,md,json}\" --config .prettierrc",
    "test:e2e": "bunx playwright test --config playwright.config.ts",
    "allure:generate": "bunx allure generate allure-results --clean -o allure-report",
    "allure:open": "bunx allure open allure-report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdamWozniewski/multiple_lang_sandbox.git"
  },
  "author": "adamw",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/AdamWozniewski/multiple_lang_sandbox/issues"
  },
  "homepage": "https://github.com/AdamWozniewski/multiple_lang_sandbox#readme",
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.55.0",
    "@types/dotenv": "^8.2.3",
    "allure-commandline": "^2.34.1",
    "allure-playwright": "^3.4.1",
    "autoprefixer": "^10.4.21",
    "cssnano": "^7.1.1",
    "dotenv": "^17.2.2",
    "eslint": "^9.35.0",
    "globals": "^16.4.0",
    "jest": "^30.1.3",
    "less": "^4.4.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "prettier": "^3.6.2",
    "sass": "^1.92.1",
    "sharp": "^0.34.3",
    "storybook": "^9.1.5",
    "tailwindcss": "^4.1.13",
    "ts-jest": "^29.4.1",
    "turbo": "^2.5.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "vite": "^7.1.5",
    "vite-plugin-image-optimizer": "^2.0.2",
    "vite-plugin-static-copy": "^3.1.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "i18next": "^24.2.0"
  },
  "optionalDependencies": {

  }
}
