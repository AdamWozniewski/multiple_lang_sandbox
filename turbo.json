{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["bun.lockb"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "packages/*/dist/**",
        "packages/*/build/**",
        "packages/*/public/main.css"
      ]
    },
    "dev": { "cache": false, "persistent": true },
    "test": { "dependsOn": ["^build"], "outputs": ["coverage/**"] },
    "lint": { "outputs": [] },
    "format": { "outputs": [] }
  }
}
